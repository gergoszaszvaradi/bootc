{
    "edit_predictions": {
        "mode": "subtle"
    },
    "cli_default_open_behavior": "new_window",
    "window_decorations": "server",
    "centered_layout": {
        "left_padding": 0.2
    },
    "bottom_dock_layout": "contained",
    "tabs": {
        "file_icons": false,
        "git_status": false
    },
    "diagnostics": {
        "button": true
    },
    "status_bar": {
        "active_language_button": false
    },
    "search": {
        "button": false,
        "case_sensitive": true
    },
    "colorize_brackets": false,
    "middle_click_paste": false,
    "indent_guides": {
        "background_coloring": "disabled",
        "coloring": "indent_aware",
        "active_line_width": 2,
        "line_width": 1,
        "enabled": true
    },
    "tab_size": 4,
    "hard_tabs": false,
    "scrollbar": {
        "git_diff": false,
        "show": "auto"
    },
    "relative_line_numbers": "disabled",
    "gutter": {
        "bookmarks": false,
        "folds": false,
        "breakpoints": false,
        "min_line_number_digits": 1,
        "runnables": false,
        "line_numbers": true
    },
    "auto_signature_help": false,
    "sticky_scroll": {
        "enabled": false
    },
    "show_wrap_guides": false,
    "rounded_selection": false,
    "ui_font_family": "CaskaydiaCove Nerd Font",
    "icon_theme": "Zed (Default)",
    "title_bar": {
        "show_menus": false,
        "show_user_menu": false,
        "show_sign_in": false,
        "show_project_items": true,
        "show_branch_icon": false
    },
    "features": {
        "edit_prediction_provider": "copilot"
    },
    "notification_panel": {
        "button": false,
        "dock": "left"
    },
    "debugger": {
        "dock": "right"
    },
    "agent": {
        "dock": "left",
        "default_profile": "write",
        "default_model": {
            "effort": "high",
            "enable_thinking": true,
            "provider": "copilot_chat",
            "model": "claude-opus-4.6"
        },
        "button": true
    },
    "collaboration_panel": {
        "dock": "right",
        "button": false
    },
    "base_keymap": "VSCode",
    "telemetry": {
        "diagnostics": false,
        "metrics": false
    },
    "ui_font_size": 16.0,
    "buffer_font_family": "CaskaydiaCove Nerd Font",
    "buffer_font_size": 16,
    "buffer_line_height": "standard",
    "buffer_font_features": {
        "ligatures": true
    },
    "terminal": {
        "font_family": "CaskaydiaCove Nerd Font",
        "line_height": "standard",
        "shell": {
            "program": "bash"
        },
        "button": false
    },
    "cursor_shape": "bar",
    "tab_bar": {
        "show_tab_bar_buttons": true,
        "show_nav_history_buttons": false,
        "show": false
    },
    "toolbar": {
        "code_actions": false,
        "agent_review": false,
        "selections_menu": false,
        "breadcrumbs": true,
        "quick_actions": false
    },
    "inlay_hints": {
        "enabled": false
    },
    "show_whitespaces": "none",
    "preview_tabs": {
        "enable_preview_from_file_finder": true,
        "enable_keep_preview_on_code_navigation": true
    },
    "project_panel": {
        "hide_root": false,
        "indent_guides": {
            "show": "always"
        },
        "show_diagnostics": "all",
        "starts_open": false,
        "indent_size": 20.0,
        "git_status": true,
        "folder_icons": true,
        "file_icons": true,
        "entry_spacing": "standard",
        "button": true,
        "dock": "right",
        "auto_fold_dirs": false
    },
    "outline_panel": {
        "dock": "right",
        "button": false
    },
    "git_panel": {
        "dock": "left",
        "tree_view": false,
        "button": false
    },
    "preferred_line_length": 200,
    "formatter": "language_server",
    "format_on_save": "on",
    "auto_install_extensions": {
        "tomorrow-theme": true,
        "html": true,
        "dockerfile": true,
        "docker-compose": true,
        "make": true,
        "xml": true
    },
    "theme": {
        "mode": "system",
        "light": "One Light",
        "dark": "Doom Tomorrow Night"
    }
}
